# Required — Railway injects this automatically when you add the PostgreSQL plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Required — port to listen on (Railway injects this automatically)
PORT=8080

# Required — basic auth password for /api/admin dashboard
ADMIN_PASSWORD=your-admin-password

# Optional — enables real restaurant data (falls back to mock SF data if unset)
GOOGLE_PLACES_API_KEY=your-google-places-key

# Optional — express session secret
SESSION_SECRET=your-session-secret
